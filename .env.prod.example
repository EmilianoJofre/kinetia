# =============================================
# Kinetia + Panorama - Variables de entorno PRODUCCIÓN
# =============================================
# Copiar como .env.prod y completar los valores
# NUNCA commitear .env.prod al repositorio

# ─── Kinetia ────────────────────────────────
DB_USER=kinetia
DB_PASSWORD=CAMBIAR_POR_PASSWORD_FUERTE_AQUI

RAILS_ENV=production

# openssl rand -hex 64
SECRET_KEY_BASE=GENERAR_CON_openssl_rand_hex_64

# openssl rand -hex 32
JWT_SECRET=GENERAR_CON_openssl_rand_hex_32

# ─── Panorama ───────────────────────────────
PANORAMA_DB_USER=panorama
PANORAMA_DB_PASSWORD=CAMBIAR_POR_PASSWORD_FUERTE_AQUI

# openssl rand -hex 64
PANORAMA_SECRET_KEY_BASE=GENERAR_CON_openssl_rand_hex_64

# cat panorama/backend/config/master.key  (valor: d18bc5adc24f574a8fb1ab2176eedf8a)
PANORAMA_RAILS_MASTER_KEY=PEGAR_VALOR_DE_master.key
